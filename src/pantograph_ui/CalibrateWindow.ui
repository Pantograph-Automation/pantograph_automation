  <property name="styleSheet">
   <string notr="true">/* --- Global &amp; Base Widget --- */
QWidget {
    background-color: #ffffff;
    color: #333333;
    font-family: &quot;Segoe UI&quot;, &quot;Helvetica Neue&quot;, sans-serif;
    font-size: 14px;
}

/* --- Labels --- */
/* Normal Text Label */
QLabel {
    color: #666666;
    background: transparent;
}

/* Header Label (Set objectName to 'headerLabel') */
QLabel#headerLabel {
    font-size: 24px;
    font-weight: bold;
    color: #1a1a1a;
    margin-bottom: 10px;
}

/* --- Buttons --- */
/* Primary Button (Default) - Dark &amp; Solid */
QPushButton {
    background-color: #1a1a1a;
    color: #ffffff;
    border: none;
    border-radius: 5px;
    padding: 10px 20px;
    font-weight: 600;
}

QPushButton:hover {
    background-color: #333333;
}

QPushButton:pressed {
    background-color: #000000;
}

/* Secondary Button (Set objectName to 'secondaryButton') - Outlined */
QPushButton#secondaryButton {
    background-color: transparent;
    color: #1a1a1a;
    border: 1px solid #1a1a1a;
}

QPushButton#secondaryButton:hover {
    background-color: #f4f4f4;
}

QPushButton#secondaryButton:pressed {
    background-color: #e0e0e0;
}

/* --- Checkbox --- */
QCheckBox {
    spacing: 10px;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 1px solid #cccccc;
    border-radius: 3px;
    background-color: white;
}

QCheckBox::indicator:hover {
    border: 1px solid #1a1a1a;
}

QCheckBox::indicator:checked {
    background-color: #1a1a1a;
    border: 1px solid #1a1a1a;
    /* Note: To show a checkmark icon, you would typically 
       reference a resource file image here */
}</string>
