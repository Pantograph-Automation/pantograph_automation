   <string notr="true">QWidget {
    background-color: #f6f8fb;
    color: #1f2937;
    font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
    font-size: 14px;
}

QFrame#headerFrame,
QFrame#setupFrame,
QFrame#progressFrame,
QFrame#metricsFrame,
QFrame#poseFrame {
    background-color: #ffffff;
    border: 1px solid #d9e2ec;
    border-radius: 8px;
}

QLabel {
    background: transparent;
    color: #475569;
}

QLabel#titleLabel {
    color: #0f172a;
    font-size: 28px;
    font-weight: 700;
}

QLabel#sectionLabel,
QLabel#cycleTitleLabel {
    color: #111827;
    font-size: 17px;
    font-weight: 700;
}

QLabel#readinessLabel {
    color: #ffffff;
    border-radius: 16px;
    padding: 6px 14px;
    font-weight: 700;
}

QLabel#stateLabel {
    color: #334155;
    font-size: 16px;
    font-weight: 700;
}

QLabel#detailLabel,
QLabel#poseValueLabel {
    color: #64748b;
}

QLabel#metricValueLabel,
QLabel#detectedValueLabel,
QLabel#transferredValueLabel,
QLabel#nextBatchValueLabel {
    color: #0f172a;
    font-size: 24px;
    font-weight: 700;
}

QComboBox {
    background-color: #ffffff;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    padding: 8px 12px;
    min-height: 22px;
}

QComboBox:disabled {
    background-color: #eef2f7;
    color: #94a3b8;
}

QProgressBar {
    background-color: #e8edf4;
    border: none;
    border-radius: 6px;
    height: 12px;
    text-align: center;
    color: transparent;
}

QProgressBar::chunk {
    background-color: #2563eb;
    border-radius: 6px;
}

QPushButton {
    border: none;
    border-radius: 6px;
    padding: 11px 18px;
    font-weight: 700;
}

QPushButton#runButton {
    background-color: #1d4ed8;
    color: #ffffff;
}

QPushButton#runButton:hover {
    background-color: #1e40af;
}

QPushButton#calibrateButton {
    background-color: #ffffff;
    color: #1d4ed8;
    border: 1px solid #93c5fd;
}

QPushButton#calibrateButton:hover {
    background-color: #eff6ff;
}

QPushButton:disabled {
    background-color: #e2e8f0;
    color: #94a3b8;
    border: 1px solid #dbe3ee;
}</string>
